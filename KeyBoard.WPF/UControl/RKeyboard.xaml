<UserControl x:Class="KeyBoard.WPF.UControl.RKeyboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KeyBoard.WPF.UControl"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:attach="clr-namespace:KeyBoard.WPF.Controls.Attach"
             mc:Ignorable="d" Focusable="False" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="400" d:DesignWidth="1280" >
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#CC000000"/>
        <sys:Double x:Key="PrimaryFontSize">24</sys:Double>
        <sys:Double x:Key="SecondFontSize">16</sys:Double>
        <LinearGradientBrush x:Key="KeyGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F5F5F5" Offset="1"/>
        </LinearGradientBrush>
        <DropShadowEffect x:Key="KeyShadow" BlurRadius="3" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
        <Style TargetType="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D5D5D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.AlphabetKeyFontSize)}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryForegroundBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="4 0 4 8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!--<Setter Property="Effect" Value="{StaticResource KeyShadow}"/>-->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5.3"
                                Effect="{TemplateBinding Effect}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!--<Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E3F2FD" Offset="0"/>
                                <GradientStop Color="#BBDEFB" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>-->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#9AB7EF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumberAndSymbolKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.NumberAndSymbolKeyFontSize)}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5.3">
                            <UniformGrid Rows="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="{TemplateBinding FontSize}" Background="Transparent" Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="{TemplateBinding FontSize}" Background="Transparent" Foreground="{TemplateBinding Foreground}"/>
                            </UniformGrid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FunctionKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.FunctionKeyFontSize)}"/>
            <Setter Property="Background" Value="#DCDCDC"/>
        </Style>
        <Style x:Key="FKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.FKeyFontSize)}"/>
            <Setter Property="Background" Value="#DCDCDC"/>
        </Style>
        <!--<Style x:Key="SpecialKeyStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{StaticResource SecondFontSize}"/>
            <Setter Property="Background" Value="#DCDCDC"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFF9C4" Offset="0"/>
                        <GradientStop Color="#FFF59D" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>-->

        <!-- ToggleButton样式：用于Ctrl、Alt、Shift、CapsLock、Fn -->
        <Style x:Key="ToggleKeyStyle" TargetType="ToggleButton">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.FunctionKeyFontSize)}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#D5D5D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="4 0 4 8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5.3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!--<Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E3F2FD" Offset="0"/>
                                <GradientStop Color="#BBDEFB" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>-->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#9AB7EF"/>
                </Trigger>
                <!-- 选中状态 -->
                <Trigger Property="IsChecked" Value="True">
                    <!--<Setter Property="Background" Value="#F3C6CD"/>-->
                    <Setter Property="Background" Value="#F3C5CD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border CornerRadius="16 16 0 0" d:Background="#F3F3F3" Background="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.Background)}">
        <Grid ButtonBase.Click="Grid_Click" Margin="4 0 4 3">
            <Grid.RowDefinitions>
                <RowDefinition Height="29"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border>
                <Border Width="80" Height="8" CornerRadius="5" Background="#C5C5C5"/>
            </Border>

            <UniformGrid Grid.Row="1" Rows="1" Columns="15">
                <Button d:FontSize="16" Content="Esc" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F1" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F2" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F3" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F4" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F5" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F6" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F7" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F8" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F9" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F10" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F11" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="F12" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="INS" Style="{StaticResource FKeyButtonStyle}"/>
                <Button d:FontSize="16" Content="Del" Style="{StaticResource FKeyButtonStyle}"/>
            </UniformGrid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" >
                    <StackPanel>
                        <TextBlock Text="~" FontSize="11" Foreground="#666" Margin="0,-2,0,-4"/>
                        <TextBlock Text="`" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="0" Content="`" Tag="~" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="1" Content="1" Tag="!" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="2" Content="2" Tag="@" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="3" Content="3" Tag="#" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="4" Content="4" Tag="$" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="5" Content="5" Tag="%" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="6" Content="6" Tag="^" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="7" Content="7" Tag="&amp;" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="8" Content="8" Tag="*" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="9" Content="9" Tag="(" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="10" Content="0" Tag=")" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="11" Content="-" Tag="_" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="12" Content="=" Tag="+" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>

                <Button Grid.Column="13" Content="Backspace" HorizontalContentAlignment="Right" Padding="0 0 25 0" Style="{StaticResource FunctionKeyButtonStyle}"/>
            </Grid>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.54*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.54*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"  d:FontSize="24" Content="Tab"/>
                <Button Grid.Column="1"  d:FontSize="24" Content="Q" />
                <Button Grid.Column="2"  d:FontSize="24" Content="W" />
                <Button Grid.Column="3"  d:FontSize="24" Content="E" />
                <Button Grid.Column="4"  d:FontSize="24" Content="R" />
                <Button Grid.Column="5"  d:FontSize="24" Content="T" />
                <Button Grid.Column="6"  d:FontSize="24" Content="Y" />
                <Button Grid.Column="7"  d:FontSize="24" Content="U" />
                <Button Grid.Column="8"  d:FontSize="24" Content="I" />
                <Button Grid.Column="9"  d:FontSize="24" Content="O" />
                <Button Grid.Column="10" d:FontSize="24" Content="P" />
                <Button Grid.Column="11" Content="[" Tag="{}{" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="12" Content="]" Tag="{}}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="13" Content="\" Tag="|" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
            </Grid>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2.1*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton Grid.Column="0" x:Name="tgCapsLock" Content="CAPS" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="1" Content="A" />
                <Button Grid.Column="2" Content="S" />
                <Button Grid.Column="3" Content="D" />
                <Button Grid.Column="4" Content="F" />
                <Button Grid.Column="5" Content="G" />
                <Button Grid.Column="6" Content="H" />
                <Button Grid.Column="7" Content="J" />
                <Button Grid.Column="8" Content="K" />
                <Button Grid.Column="9" Content="L" />
                <Button Grid.Column="10" Content=";" Tag=":" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="11" Content="'" Tag="&quot;" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="12" Content="Enter" Style="{StaticResource FunctionKeyButtonStyle}"/>
            </Grid>
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.65*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2.65*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="tgShift1" Grid.Column="0" Content="Shift" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="1" Content="Z" />
                <Button Grid.Column="2" Content="X" />
                <Button Grid.Column="3" Content="C" />
                <Button Grid.Column="4" Content="V" />
                <Button Grid.Column="5" Content="B" />
                <Button Grid.Column="6" Content="N" />
                <Button Grid.Column="7" Content="M" />
                <Button Grid.Column="8" Content="," Tag="&lt;" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="9" Content="." Tag="&gt;" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="10" Content="/" Tag="?" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <ToggleButton x:Name="tgShift2" Grid.Column="11" Content="Shift" IsChecked="{Binding ElementName=tgShift1, Path=IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ToggleKeyStyle}"/>
            </Grid>
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="8.7*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="tgCtrl1" Grid.Column="0" Content="Ctrl" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="1" Content="Win" Style="{StaticResource FunctionKeyButtonStyle}"/>
                <ToggleButton x:Name="tgAlt1" Grid.Column="2" Content="Alt" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="3" Content="Space"  FontSize="16"/>
                <ToggleButton x:Name="tgAlt2" Grid.Column="4" Content="Alt" IsChecked="{Binding ElementName=tgAlt1, Path=IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ToggleKeyStyle}"/>
                <ToggleButton Grid.Column="5" Content="Fn" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="6" Content="☰" Style="{StaticResource FunctionKeyButtonStyle}"/>
                <ToggleButton x:Name="tgCtrl2" Grid.Column="7" Content="Ctrl" IsChecked="{Binding ElementName=tgCtrl1, Path=IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ToggleKeyStyle}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
