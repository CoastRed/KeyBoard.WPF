<UserControl x:Class="KeyBoard.WPF.UControl.Keyboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:KeyBoard.WPF.UControl"
             xmlns:attach="clr-namespace:KeyBoard.WPF.Controls.Attach"
             xmlns:input="clr-namespace:System.Windows.Input;assembly=WindowsBase"
             mc:Ignorable="d" Focusable="False" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded"
             d:DesignHeight="350" d:DesignWidth="800" >
    <UserControl.Resources>
        <LinearGradientBrush x:Key="KeyGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F5F5F5" Offset="1"/>
        </LinearGradientBrush>
        <DropShadowEffect x:Key="KeyShadow" BlurRadius="3" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
        <Style TargetType="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource KeyGradient}"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.AlphabetKeyFontSize)}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource KeyShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Effect="{TemplateBinding Effect}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E3F2FD" Offset="0"/>
                                <GradientStop Color="#BBDEFB" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#BBDEFB" Offset="0"/>
                                <GradientStop Color="#90CAF9" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NumberAndSymbolKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.NumberAndSymbolKeyFontSize)}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Effect="{TemplateBinding Effect}">
                            <Grid>
                                <TextBlock x:Name="tb1"  Margin="3 3 0 0" FontSize="15" Background="Transparent" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Top"/>
                                <ContentPresenter x:Name="cp1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="`">
                                <Setter TargetName="cp1" Property="VerticalAlignment" Value="Bottom"/>
                            </Trigger>
                            <Trigger Property="Content" Value="`">
                                <Setter TargetName="tb1" Property="Text" Value="~"/>
                            </Trigger>
                            <Trigger Property="Content" Value="1">
                                <Setter TargetName="tb1" Property="Text" Value="!"/>
                            </Trigger>
                            <Trigger Property="Content" Value="2">
                                <Setter TargetName="tb1" Property="Text" Value="@"/>
                            </Trigger>
                            <Trigger Property="Content" Value="3">
                                <Setter TargetName="tb1" Property="Text" Value="#"/>
                            </Trigger>
                            <Trigger Property="Content" Value="4">
                                <Setter TargetName="tb1" Property="Text" Value="$"/>
                            </Trigger>
                            <Trigger Property="Content" Value="5">
                                <Setter TargetName="tb1" Property="Text" Value="%"/>
                            </Trigger>
                            <Trigger Property="Content" Value="6">
                                <Setter TargetName="tb1" Property="Text" Value="^"/>
                            </Trigger>
                            <Trigger Property="Content" Value="7">
                                <Setter TargetName="tb1" Property="Text" Value="&amp;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="8">
                                <Setter TargetName="tb1" Property="Text" Value="*"/>
                            </Trigger>
                            <Trigger Property="Content" Value="9">
                                <Setter TargetName="tb1" Property="Text" Value="("/>
                            </Trigger>
                            <Trigger Property="Content" Value="0">
                                <Setter TargetName="tb1" Property="Text" Value=")"/>
                            </Trigger>
                            <Trigger Property="Content" Value="-">
                                <Setter TargetName="tb1" Property="VerticalAlignment" Value="Top"/>
                                <Setter TargetName="tb1" Property="Margin" Value="3 -6 0 0"/>
                                <Setter TargetName="tb1" Property="Text" Value="_"/>
                            </Trigger>
                            <Trigger Property="Content" Value="=">
                                <Setter TargetName="tb1" Property="Text" Value="+"/>
                            </Trigger>
                            <Trigger Property="Content" Value="[">
                                <Setter TargetName="tb1" Property="Text" Value="{}{"/>
                            </Trigger>
                            <Trigger Property="Content" Value="]">
                                <Setter TargetName="tb1" Property="Text" Value="{}}"/>
                            </Trigger>
                            <Trigger Property="Content" Value="\">
                                <Setter TargetName="tb1" Property="Text" Value="|"/>
                            </Trigger>
                            <Trigger Property="Content" Value=";">
                                <Setter TargetName="tb1" Property="Text" Value=":"/>
                            </Trigger>
                            <Trigger Property="Content" Value="'">
                                <Setter TargetName="tb1" Property="Text" Value="&quot;"/>
                            </Trigger>
                            <Trigger Property="Content" Value=",">
                                <Setter TargetName="tb1" Property="Text" Value="&lt;"/>
                            </Trigger>
                            <Trigger Property="Content" Value=".">
                                <Setter TargetName="tb1" Property="Text" Value="&gt;"/>
                            </Trigger>
                            <Trigger Property="Content" Value="/">
                                <Setter TargetName="tb1" Property="Text" Value="?"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.FKeyFontSize)}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E0E0E0" Offset="0"/>
                        <GradientStop Color="#BDBDBD" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FunctionKeyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.FunctionKeyFontSize)}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFF9C4" Offset="0"/>
                        <GradientStop Color="#FFF59D" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ToggleButton样式：用于Ctrl、Alt、Shift、CapsLock、Fn -->
        <Style x:Key="ToggleKeyStyle" TargetType="ToggleButton">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.FunctionKeyFontSize)}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFF9C4" Offset="0"/>
                        <GradientStop Color="#FFF59D" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource KeyShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Effect="{TemplateBinding Effect}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#E3F2FD" Offset="0"/>
                                <GradientStop Color="#BBDEFB" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#BBDEFB" Offset="0"/>
                                <GradientStop Color="#90CAF9" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#1976D2"/>
                </Trigger>
                <!-- 选中状态 -->
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#4CAF50" Offset="0"/>
                                <GradientStop Color="#388E3C" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderBrush" Value="#2E7D32"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border CornerRadius="10" Background="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=(attach:KeyBoardAttach.Background)}">
        <Grid Margin="10" ButtonBase.Click="Grid_Click">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1.2*"/>
            </Grid.RowDefinitions>
            <UniformGrid Grid.Row="0" Rows="1" Columns="15" Margin="0 0 0 5">
                <Button Content="Esc" Tag="{x:Static input:Key.Escape}" Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F1"  Tag="{x:Static input:Key.F1}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F2"  Tag="{x:Static input:Key.F2}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F3"  Tag="{x:Static input:Key.F3}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F4"  Tag="{x:Static input:Key.F4}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F5"  Tag="{x:Static input:Key.F5}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F6"  Tag="{x:Static input:Key.F6}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F7"  Tag="{x:Static input:Key.F7}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F8"  Tag="{x:Static input:Key.F8}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F9"  Tag="{x:Static input:Key.F9}"     Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F10" Tag="{x:Static input:Key.F10}"    Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F11" Tag="{x:Static input:Key.F11}"    Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="F12" Tag="{x:Static input:Key.F12}"    Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="INS" Tag="{x:Static input:Key.Insert}" Style="{StaticResource FKeyButtonStyle}"/>
                <Button Content="Del" Tag="{x:Static input:Key.Delete}" Style="{StaticResource FKeyButtonStyle}"/>
            </UniformGrid>
            <Grid Grid.Row="1" Margin="0 0 0 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" >
                    <StackPanel>
                        <TextBlock Text="~" FontSize="11" Foreground="#666" Margin="0,-2,0,-4"/>
                        <TextBlock Text="`" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="0" Content="`"  Tag="{x:Static input:Key.OemTilde}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="1" Content="1"  Tag="{x:Static input:Key.D1}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="2" Content="2"  Tag="{x:Static input:Key.D2}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="3" Content="3"  Tag="{x:Static input:Key.D3}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="4" Content="4"  Tag="{x:Static input:Key.D4}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="5" Content="5"  Tag="{x:Static input:Key.D5}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="6" Content="6"  Tag="{x:Static input:Key.D6}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="7" Content="7"  Tag="{x:Static input:Key.D7}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="8" Content="8"  Tag="{x:Static input:Key.D8}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="9" Content="9"  Tag="{x:Static input:Key.D9}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="10" Content="0" Tag="{x:Static input:Key.D0}"       Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="11" Content="-" Tag="{x:Static input:Key.OemMinus}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="12" Content="=" Tag="{x:Static input:Key.OemPlus}"  Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>

                <Button Grid.Column="13" Content="Backspace" Tag="{x:Static input:Key.Back}" Style="{StaticResource FKeyButtonStyle}"/>
            </Grid>
            <Grid Grid.Row="2" Margin="0 0 0 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Tab" Tag="{x:Static input:Key.Tab}" Style="{StaticResource FKeyButtonStyle}"/>
                <Button Grid.Column="1" Content="Q"   Tag="{x:Static input:Key.Q}"   />
                <Button Grid.Column="2" Content="W"   Tag="{x:Static input:Key.W}"   />
                <Button Grid.Column="3" Content="E"   Tag="{x:Static input:Key.E}"   />
                <Button Grid.Column="4" Content="R"   Tag="{x:Static input:Key.R}"   />
                <Button Grid.Column="5" Content="T"   Tag="{x:Static input:Key.T}"   />
                <Button Grid.Column="6" Content="Y"   Tag="{x:Static input:Key.Y}"   />
                <Button Grid.Column="7" Content="U"   Tag="{x:Static input:Key.U}"   />
                <Button Grid.Column="8" Content="I"   Tag="{x:Static input:Key.I}"   />
                <Button Grid.Column="9" Content="O"   Tag="{x:Static input:Key.O}"   />
                <Button Grid.Column="10" Content="P"  Tag="{x:Static input:Key.P}"   />
                <Button Grid.Column="11" Content="[" Tag="{x:Static input:Key.OemOpenBrackets}"  Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="12" Content="]" Tag="{x:Static input:Key.OemCloseBrackets}"  Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="13" Content="\" Tag="{x:Static input:Key.OemBackslash}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
            </Grid>
            <Grid Grid.Row="3" Margin="0 0 0 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2.2*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton Grid.Column="0" x:Name="tgCapsLock" Content="CAPS" Tag="{x:Static input:Key.CapsLock}" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="1" Content="A" Tag="{x:Static input:Key.A}"/>
                <Button Grid.Column="2" Content="S" Tag="{x:Static input:Key.S}"/>
                <Button Grid.Column="3" Content="D" Tag="{x:Static input:Key.D}"/>
                <Button Grid.Column="4" Content="F" Tag="{x:Static input:Key.F}"/>
                <Button Grid.Column="5" Content="G" Tag="{x:Static input:Key.G}"/>
                <Button Grid.Column="6" Content="H" Tag="{x:Static input:Key.H}"/>
                <Button Grid.Column="7" Content="J" Tag="{x:Static input:Key.J}"/>
                <Button Grid.Column="8" Content="K" Tag="{x:Static input:Key.K}"/>
                <Button Grid.Column="9" Content="L" Tag="{x:Static input:Key.L}"/>
                <Button Grid.Column="10" Content=";" Tag="{x:Static input:Key.OemSemicolon}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="11" Content="'" Tag="{x:Static input:Key.OemQuotes}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="12" Content="Enter" Tag="{x:Static input:Key.Enter}" Style="{StaticResource FKeyButtonStyle}"/>
            </Grid>
            <Grid Grid.Row="4" Margin="0 0 0 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2.7*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="tgShift1" Grid.Column="0" Content="Shift" Tag="{x:Static input:Key.LeftShift}" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="1" Content="Z" Tag="{x:Static input:Key.Z}"/>
                <Button Grid.Column="2" Content="X" Tag="{x:Static input:Key.X}"/>
                <Button Grid.Column="3" Content="C" Tag="{x:Static input:Key.C}"/>
                <Button Grid.Column="4" Content="V" Tag="{x:Static input:Key.V}"/>
                <Button Grid.Column="5" Content="B" Tag="{x:Static input:Key.B}"/>
                <Button Grid.Column="6" Content="N" Tag="{x:Static input:Key.N}"/>
                <Button Grid.Column="7" Content="M" Tag="{x:Static input:Key.M}"/>
                <Button Grid.Column="8" Content="," Tag="{x:Static input:Key.OemComma}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="9" Content="." Tag="{x:Static input:Key.OemPeriod}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <Button Grid.Column="10" Content="/" Tag="{x:Static input:Key.OemQuestion}" Style="{StaticResource NumberAndSymbolKeyButtonStyle}"/>
                <ToggleButton x:Name="tgShift2" Grid.Column="11" Content="Shift" Tag="{x:Static input:Key.LeftShift}" IsChecked="{Binding ElementName=tgShift1, Path=IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ToggleKeyStyle}"/>
            </Grid>
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>
                <ToggleButton x:Name="tgCtrl1" Grid.Column="0" Content="Ctrl" Tag="{x:Static input:Key.LeftCtrl}" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="1" Content="Win" Tag="{x:Static input:Key.LWin}" Style="{StaticResource FunctionKeyButtonStyle}"/>
                <ToggleButton x:Name="tgAlt1" Grid.Column="2" Content="Alt" Tag="{x:Static input:Key.LeftAlt}" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="3" Content="Space" Tag="{x:Static input:Key.Space}" FontSize="16"/>
                <ToggleButton x:Name="tgAlt2" Grid.Column="4" Content="Alt" Tag="{x:Static input:Key.LeftAlt}" IsChecked="{Binding ElementName=tgAlt1, Path=IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ToggleKeyStyle}"/>
                <ToggleButton Grid.Column="5" Content="Fn" Style="{StaticResource ToggleKeyStyle}"/>
                <Button Grid.Column="6" Content="☰" Style="{StaticResource FunctionKeyButtonStyle}"/>
                <ToggleButton x:Name="tgCtrl2" Grid.Column="7" Content="Ctrl" Tag="{x:Static input:Key.LeftCtrl}" IsChecked="{Binding ElementName=tgCtrl1, Path=IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ToggleKeyStyle}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
